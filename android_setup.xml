<!-- ── HOW TO GENERATE YOUR KEYSTORE ─────────────────────────────────────────
     Run this once locally, then base64-encode the .jks for Codemagic.

     keytool -genkeypair \
       -alias rydecircle_rider \
       -keyalg RSA -keysize 2048 \
       -validity 10000 \
       -keystore rydecircle_rider.jks \
       -dname "CN=RydeCircle, OU=Mobile, O=RydeCircle Ltd, L=Lagos, ST=Lagos, C=NG"

     Then base64-encode it:
       macOS:   base64 -i rydecircle_rider.jks | pbcopy
       Linux:   base64 rydecircle_rider.jks | xclip -selection clipboard

     Paste the output as the CM_KEYSTORE environment variable in Codemagic.
     ──────────────────────────────────────────────────────────────────────── -->
