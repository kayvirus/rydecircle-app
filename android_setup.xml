     ANDROID SETUP REFERENCE — RydeCircle Rider App
     Two files to edit before your first build.
     ═══════════════════════════════════════════════════════════════════════════ -->


<!-- ── FILE 1: android/app/src/main/AndroidManifest.xml ─────────────────────
     Add these <uses-permission> lines inside <manifest>, before <application>
     ──────────────────────────────────────────────────────────────────────── -->

    <!-- Internet (required for API calls and Paystack) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera — for taking profile photo and NIN document photo -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Read storage — Android 12 and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Read images — Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />


<!-- ── FILE 2: android/app/build.gradle ─────────────────────────────────────
     Full replacement for the android { } block in your app-level build.gradle
     ──────────────────────────────────────────────────────────────────────── -->

